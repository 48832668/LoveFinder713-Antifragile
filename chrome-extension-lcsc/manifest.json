{
  "manifest_version": 3,
  "name": "LoveFinder713-Antifragile_电子元器件信息捕获",
  "version": "26.2.24",
  "description": "读取立创商城或者其他元器件商城的详情页信息并支持添加到LoveFinder704-ElecAntifreeze系统",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Antifragile电子元器件信息捕获"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://item.szlcsc.com/*",
    "http://localhost:11451/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://item.szlcsc.com/*.html*"],
      "js": [
        "Layer3_UI.js"
      ],
      "css": [
        "css/bootstrap.min.css",
        "css/bootstrap-icons.min.css",
        "content-style.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
