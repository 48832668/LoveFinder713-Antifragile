{
  "manifest_version": 3,
  "name": "LCSC订单信息解析器",
  "version": "1.0.0",
  "description": "解析LCSC订单页面，在悬浮面板中展示订单列表和元器件详情",
  
  "permissions": [
    "storage",
    "activeTab"
  ],
  
  "host_permissions": [
    "https://member.szlcsc.com/*",
    "https://www.szlcsc.com/*",
    "http://localhost:11451/*",
    "file:///*"
  ],
  
  "background": {
    "service_worker": "scripts/background.js"
  },
  
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "LCSC订单解析器"
  },
  
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  
  "content_scripts": [
    {
      "matches": [
        "https://member.szlcsc.com/member/order/*",
        "https://member.szlcsc.com/*order*",
        "file:///*test-page.html*"
      ],
      "js": ["scripts/content-script.js"],
      "css": ["styles/content-style.css"],
      "run_at": "document_idle"
    }
  ]
}
